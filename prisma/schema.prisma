generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Member {
  id          String   @id @default(cuid())
  name        String
  role        String
  description String?
  photoUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  imageUrl    String?
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Categories: Event, Forum, Project
model GalleryImage {
  id          String   @id @default(cuid())
  title       String
  description String?
  imageUrl    String
  category    String   
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Stats 
model Stat {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Int
  createdAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Application {
  id              String   @id @default(cuid())
  fullName        String
  phone           String
  email           String
  fieldOfStudy    String?
  skills          String?
  interests       String?
  motivation      String?
  status          String   @default("New") // New, Contacted, Accepted, Rejected
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Global configurations (e.g., hero image, texts)
model SiteConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model HistoryEntry {
  id          String   @id @default(cuid())
  year        String
  title       String
  description String
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Achievement {
  id          String   @id @default(cuid())
  title       String
  year        String
  description String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Trainer {
  id          String   @id @default(cuid())
  name        String
  specialty   String
  bio         String?
  photoUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
